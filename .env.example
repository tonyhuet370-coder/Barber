PORT=3000
OWNER_EMAIL=boss@monsalon.com
MAIL_FROM=votre_adresse_gmail
# OWNER_EMAIL doit etre l'adresse du coiffeur pour recevoir le code de recuperation admin

# SMTP Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=votre_adresse_gmail
SMTP_PASS=votre_mot_de_passe_application_google
SMTP_FAMILY=4

# Admin dashboard login
ADMIN_USERNAME=admin
# Option simple (moins securisee)
ADMIN_PASSWORD=change-me
# Option recommandee: stocker un hash illisible au lieu du mot de passe en clair
# ADMIN_PASSWORD_HASH=sel:hash
# Code de recuperation pour renouveler l'identifiant et le mot de passe en cas d'oubli
ADMIN_RESET_CODE=change-this-recovery-code
SESSION_SECRET=change-this-secret-before-production
ADMIN_LOGIN_PATH=/acces-coiffeur-prive
